# ===== Telegram =====
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=                 # international format: +84327279393
TELEGRAM_SESSION_NAME=forex_bot
TELEGRAM_SOURCE_CHATS=          # comma-separated chat IDs or usernames
TELEGRAM_ADMIN_CHAT=            # chat ID for alert notifications
SESSION_RESET_HOURS=12          # proactive Telethon session reset interval

# ===== MT5 =====
MT5_PATH=
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ===== Risk Management =====
RISK_MODE=FIXED_LOT             # FIXED_LOT or RISK_PERCENT
FIXED_LOT_SIZE=0.01
RISK_PERCENT=1.0

# ===== Safety Gates =====
MAX_SPREAD_POINTS=50
MAX_OPEN_TRADES=5
PENDING_ORDER_TTL_MINUTES=15
SIGNAL_AGE_TTL_SECONDS=60
MAX_ENTRY_DISTANCE_POINTS=500

# ===== Lot Constraints =====
LOT_MIN=0.01
LOT_MAX=100.0
LOT_STEP=0.01

# ===== Runtime =====
DRY_RUN=false                   # true = simulate execution, no real orders
ALERT_COOLDOWN_SECONDS=300      # rate limit per alert type
CIRCUIT_BREAKER_THRESHOLD=3     # consecutive failures to open breaker
CIRCUIT_BREAKER_COOLDOWN=300    # seconds before breaker auto-probes
STORAGE_RETENTION_DAYS=30       # auto-cleanup records older than this

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
LOG_ROTATION=10 MB

# ===== Parser =====
MAX_MESSAGE_LENGTH=2000
