# ===== Telegram =====
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=                 # international format: +84327279393
TELEGRAM_SESSION_NAME=forex_bot
TELEGRAM_SOURCE_CHATS=          # comma-separated chat IDs or usernames
TELEGRAM_ADMIN_CHAT=            # chat ID for alert notifications
SESSION_RESET_HOURS=12          # proactive Telethon session reset interval

# ===== MT5 =====
MT5_PATH=
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ===== Risk Management =====
RISK_MODE=FIXED_LOT             # FIXED_LOT or RISK_PERCENT
FIXED_LOT_SIZE=0.01
RISK_PERCENT=1.0

# ===== Safety Gates =====
MAX_SPREAD_POINTS=50            # reject signal if spread exceeds this
MAX_OPEN_TRADES=5               # reject signal if open positions >= this
PENDING_ORDER_TTL_MINUTES=15    # auto-cancel pending order after this
SIGNAL_AGE_TTL_SECONDS=60       # reject signal older than this
MAX_ENTRY_DISTANCE_POINTS=500   # reject if entry too far from current price

# ===== Lot Constraints =====
LOT_MIN=0.01
LOT_MAX=100.0
LOT_STEP=0.01

# ===== Trade Execution =====
# ⚠️ CRITICAL: These values directly affect real money trades
BOT_MAGIC_NUMBER=234000         # unique ID to identify bot orders in MT5
DEVIATION_POINTS=20             # max acceptable price slippage in points for market orders
MARKET_TOLERANCE_POINTS=5.0     # if |entry - live_price| ≤ tolerance * point → MARKET order
ORDER_MAX_RETRIES=3             # bounded retry count for order_send failures
ORDER_RETRY_DELAY_SECONDS=1.0   # base delay between retries (multiplied by attempt number)
WATCHDOG_INTERVAL_SECONDS=30    # MT5 health check frequency
WATCHDOG_MAX_REINIT=5           # max reinit attempts before giving up
LIFECYCLE_CHECK_INTERVAL_SECONDS=30  # how often to scan for expired pending orders

# ===== Runtime =====
DRY_RUN=false                   # true = simulate execution, no real orders
ALERT_COOLDOWN_SECONDS=300      # rate limit per alert type (prevent spam)
CIRCUIT_BREAKER_THRESHOLD=3     # consecutive failures to open breaker
CIRCUIT_BREAKER_COOLDOWN=300    # seconds before breaker auto-probes
STORAGE_RETENTION_DAYS=30       # auto-cleanup records older than this

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
LOG_ROTATION=10 MB

# ===== Parser =====
MAX_MESSAGE_LENGTH=2000
