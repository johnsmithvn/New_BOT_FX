# ===== Telegram =====
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=                 # international format: +84327279393
TELEGRAM_SESSION_NAME=forex_bot
TELEGRAM_SOURCE_CHATS=          # comma-separated chat IDs or usernames

# ===== MetaTrader 5 =====
MT5_PATH=                       # path to terminal64.exe
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# ===== Risk Management =====
RISK_MODE=FIXED_LOT             # FIXED_LOT or RISK_PERCENT
FIXED_LOT_SIZE=0.01
RISK_PERCENT=1.0                # percent of balance per trade

# ===== Safety Gates =====
MAX_SPREAD_POINTS=50            # reject if spread exceeds this
MAX_OPEN_TRADES=5
PENDING_ORDER_TTL_MINUTES=15    # auto-cancel pending after this
SIGNAL_AGE_TTL_SECONDS=60       # reject signals older than this
MAX_ENTRY_DISTANCE_POINTS=500   # reject if entry too far from market

# ===== Lot Constraints =====
LOT_MIN=0.01
LOT_MAX=100.0
LOT_STEP=0.01

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
LOG_ROTATION=10 MB

# ===== Parser =====
MAX_MESSAGE_LENGTH=2000
