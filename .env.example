# ===== Telegram =====
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=                 # international format: +84327279393
TELEGRAM_SESSION_NAME=forex_bot
TELEGRAM_SOURCE_CHATS=          # comma-separated chat IDs or usernames
TELEGRAM_ADMIN_CHAT=            # chat ID for alert notifications
SESSION_RESET_HOURS=12          # proactive Telethon session reset interval

# ===== Telegram Bot (Admin Panel) =====
TELEGRAM_BOT_TOKEN=             # Bot API token from @BotFather
TELEGRAM_BOT_ADMIN_ID=          # Your numeric Telegram user ID (get from @userinfobot)

# ===== MT5 =====
MT5_PATH=
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
SYMBOL_SUFFIX=              # broker symbol suffix (e.g. "m" for Exness: XAUUSD→XAUUSDm)

# ===== Risk Management =====
RISK_MODE=FIXED_LOT             # FIXED_LOT or RISK_PERCENT
FIXED_LOT_SIZE=0.01
RISK_PERCENT=1.0

# ===== Safety Gates (all distances in PIPS) =====
# ⚠️ XAUUSD: 1 pip = $0.10 price movement (10 points)
# ⚠️ Forex:  1 pip = 0.0001 price movement (10 points)
MAX_SPREAD_PIPS=5.0             # reject if spread > 5 pips (XAUUSD: $0.50)
MAX_OPEN_TRADES=10               # reject if open positions >= 5
PENDING_ORDER_TTL_MINUTES=15    # auto-cancel pending order after 15min
SIGNAL_AGE_TTL_SECONDS=60       # reject signal older than 60s
MAX_ENTRY_DISTANCE_PIPS=200.0    # reject if entry > 50 pips from live price (XAUUSD: $5.00)
MAX_ENTRY_DRIFT_PIPS=10.0       # tight guard: reject MARKET if entry drifted > 10 pips (XAUUSD: $1.00)

# ===== Daily Risk Guard (all default 0 = disabled) =====
MAX_DAILY_TRADES=0              # max closed trades per UTC day; 0=unlimited
MAX_DAILY_LOSS=0.0              # max cumulative loss USD per day; 0=unlimited
MAX_CONSECUTIVE_LOSSES=10        # pause after N consecutive losing trades; 0=disabled
DAILY_RISK_POLL_MINUTES=5       # how often to poll MT5 deal history

# ===== Exposure Guard (all default 0 = disabled) =====
MAX_SAME_SYMBOL_TRADES=0        # max open positions on same symbol; 0=unlimited
MAX_CORRELATED_TRADES=0         # max open across correlation group; 0=unlimited
CORRELATION_GROUPS=             # colon-separated groups, comma-separated: XAUUSD:XAGUSD,EURUSD:GBPUSD

# ===== Position Manager (all disabled by default) =====
BREAKEVEN_TRIGGER_PIPS=0.0      # pips of profit to trigger breakeven; 0=disabled
BREAKEVEN_LOCK_PIPS=2.0         # pips above entry to lock SL at (when breakeven triggers)
TRAILING_STOP_PIPS=0.0          # trail SL at this pip distance; 0=disabled
PARTIAL_CLOSE_PERCENT=0         # % of volume to close at TP1; 0=disabled
POSITION_MANAGER_POLL_SECONDS=5 # how often to check positions

# ===== Lot Constraints =====
LOT_MIN=0.01
LOT_MAX=100.0
LOT_STEP=0.01

# ===== Trade Execution =====
# ⚠️ CRITICAL: These values directly affect real money trades
BOT_MAGIC_NUMBER=234000         # unique ID to identify bot orders in MT5
DEVIATION_POINTS=30             # max slippage in points (XAUUSD: 20pts = 2 pips = $0.20)
MARKET_TOLERANCE_POINTS=30.0     # if |entry - price| ≤ tolerance * point → MARKET order
                                # XAUUSD: 30 * 0.01 = $0.30 = 3 pips
ORDER_MAX_RETRIES=3             # bounded retry for order_send failures
ORDER_RETRY_DELAY_SECONDS=1.0   # base delay between retries (× attempt number)
WATCHDOG_INTERVAL_SECONDS=30    # MT5 health check frequency
WATCHDOG_MAX_REINIT=5           # max reconnect attempts before giving up
LIFECYCLE_CHECK_INTERVAL_SECONDS=30  # scan frequency for expired pending orders
DYNAMIC_DEVIATION_MULTIPLIER=0.0    # 0=disabled; e.g. 1.5 → deviation = max(20, spread * 1.5)
TRADE_TRACKER_POLL_SECONDS=30       # poll MT5 deal history for PnL tracking; 0=disabled

# ===== Runtime =====
DRY_RUN=false                   # true = simulate, no real orders
ALERT_COOLDOWN_SECONDS=300      # rate limit per alert type (prevent spam)
CIRCUIT_BREAKER_THRESHOLD=3     # consecutive fails to pause trading
CIRCUIT_BREAKER_COOLDOWN=300    # seconds before auto-probe after breaker opens
STORAGE_RETENTION_DAYS=30       # auto-cleanup records older than this
HEARTBEAT_INTERVAL_MINUTES=30   # heartbeat log frequency; 0 = disabled
DEBUG_SIGNAL_DECISION=false     # true = send pipeline debug to admin Telegram per signal
HEALTH_CHECK_PORT=8080          # /health endpoint port (P13)

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
LOG_ROTATION=10 MB

# ===== Parser =====
MAX_MESSAGE_LENGTH=2000
